# Токен GitHub — основной (десятки бесплатных моделей, у каждой свой суточный лимит).
# Создать: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_твой_токен

# --- Необязательные бесплатные провайдеры (каждый = свой отдельный лимит) -------
# Раскомментируй строку и вставь ключ — провайдер подключится к цепочке сам.

# Groq — очень быстрый, бесплатный ключ: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# OpenRouter — бесплатные модели (Qwen, DeepSeek): https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Google Gemini — бесплатный ключ: https://aistudio.google.com/apikey
# GEMINI_API_KEY=...

# Ollama (локально, безлимит) ключа НЕ требует — просто установи Ollama
# и сделай: ollama pull qwen2.5-coder:7b
